# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# PWA generated files (auto-generated by next-pwa or workbox)
/public/sw.js
/public/sw.js.map
/public/workbox-*.js
/public/workbox-*.js.map
/public/worker-*.js
/public/worker-*.js.map
/public/swe-worker-*.js
/public/swe-worker-*.js.map
/public/fallback-*.js
/public/fallback-*.js.map

# Service Worker TypeScript definitions (if generated)
/public/sw.d.ts
/public/workbox-*.d.ts

# PWA cache files
/.pwa-cache/
/sw-cache/

# Workbox build files
/workbox-*.json